# Copy these entries into GitHub Actions Variables and Secrets.
# Variables: Settings -> Secrets and variables -> Actions -> Variables
# Secrets: Settings -> Secrets and variables -> Actions -> Secrets

# Variables
REPORTING_OWNER=Augmenting-Integrations
REPORTING_REPOSITORY=.github
REPORTING_TEAM_MAP_PATH=.github/reporting/teams.json
NEWSLETTER_DISCUSSION_CATEGORY=Announcements
PLATFORM_DRIFT_DISCUSSION_CATEGORY=Platform Reports
REPORT_ARTIFACT_RETENTION_DAYS=30
ALERTING_STUB_ENABLED=false
ALERTING_STUB_NOTE=Wire Microsoft Teams or email later.

# Secrets
# Required once your reports read private repositories outside this .github repo.
GH_TOKEN=
